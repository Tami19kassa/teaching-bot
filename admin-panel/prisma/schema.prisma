// prisma/schema.prisma
// Shared schema — used by both the bot and admin panel via DATABASE_URL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id           Int      @id @default(autoincrement())
  telegramId   BigInt   @unique                // Telegram user ID
  username     String?                         // @handle (optional)
  firstName    String
  lastName     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  payments     Payment[]
  userLevels   UserLevel[]
}

// ─── Levels ───────────────────────────────────────────────────────────────────

model Level {
  id          Int      @id @default(autoincrement())
  name        String   @unique               // e.g. "Beginner", "Advanced"
  description String?
  price       Decimal  @db.Decimal(10, 2)    // display price for the user
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  videos      Video[]
  userLevels  UserLevel[]
  payments    Payment[]
}

// ─── UserLevels (many-to-many) ────────────────────────────────────────────────

model UserLevel {
  id        Int      @id @default(autoincrement())
  userId    Int
  levelId   Int
  grantedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  level Level @relation(fields: [levelId], references: [id], onDelete: Cascade)

  @@unique([userId, levelId])
}

// ─── Payments ─────────────────────────────────────────────────────────────────

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

model Payment {
  id              Int           @id @default(autoincrement())
  userId          Int
  levelId         Int
  telegramFileId  String        // Telegram file_id of the receipt screenshot
  status          PaymentStatus @default(PENDING)
  adminNote       String?       // optional rejection/approval note
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  level Level @relation(fields: [levelId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([userId])
}

// ─── Videos ───────────────────────────────────────────────────────────────────

model Video {
  id          Int      @id @default(autoincrement())
  levelId     Int
  title       String
  description String?
  bunnyVideoId String  // Bunny Stream video GUID (from upload)
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  level Level @relation(fields: [levelId], references: [id], onDelete: Cascade)
}
